# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Flask environment: development | production
FLASK_ENV=development

# Secret key for Flask sessions (generate: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-secret

# JWT signing key (generate separately from SECRET_KEY)
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret

# JWT token lifetime in hours (default 24)
JWT_EXPIRES_HOURS=24

# Database URL
# SQLite (default, good for development):
DATABASE_URL=sqlite:///shiftsync.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/shiftsync

# OpenAI API key — required for GPT-powered chatbot responses.
# Without this the chatbot uses a built-in keyword-matching fallback.
OPENAI_API_KEY=

# CORS — comma-separated list of allowed frontend origins.
# Use * in development only. In production set the exact origin, e.g.:
# CORS_ORIGINS=https://shiftsync.yourdomain.com
CORS_ORIGINS=*
